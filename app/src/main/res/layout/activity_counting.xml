<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@android:color/white">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Skip Counter"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:layout_marginBottom="32dp" />

    <!-- Calibration Progress (shown during first 3 seconds) -->
    <LinearLayout
        android:id="@+id/calibrationContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calibrating..."
            android:textSize="16sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginBottom="12dp" />

        <ProgressBar
            android:id="@+id/calibrationProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="200dp"
            android:layout_height="8dp"
            android:progress="0"
            android:max="100" />

    </LinearLayout>

    <!-- Skip Count (Big Number) -->
    <TextView
        android:id="@+id/skipCountDisplay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textSize="96sp"
        android:textStyle="bold"
        android:textColor="@android:color/holo_blue_dark"
        android:layout_marginVertical="32dp" />

    <!-- Timer -->
    <TextView
        android:id="@+id/timerDisplay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textSize="48sp"
        android:textColor="@android:color/darker_gray"
        android:layout_marginBottom="48dp" />

    <!-- Stop Button -->
    <Button
        android:id="@+id/stopButton"
        android:layout_width="200dp"
        android:layout_height="56dp"
        android:text="Stop"
        android:textSize="18sp"
        android:textColor="@android:color/white"
        android:background="@android:color/holo_red_dark"
        android:elevation="8dp" />

</LinearLayout>